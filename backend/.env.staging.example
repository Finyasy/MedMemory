DEBUG=false
DATABASE_URL=postgresql+asyncpg://medmemory:medmemory_staging@localhost:5433/medmemory_staging
JWT_SECRET_KEY=replace-with-a-long-random-secret
FRONTEND_BASE_URL=http://localhost:4173

# Staging startup should not fail just because local embedding assets are absent.
STARTUP_REQUIRE_EMBEDDINGS=false
PRELOAD_LLM_ON_STARTUP=0

# Recommended offline/runtime defaults until staging model assets are mounted.
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# Provider sync defaults
PROVIDER_SYNC_LIVE_ENABLED=true
PROVIDER_SYNC_LIVE_FALLBACK_TO_LOCAL_SCAN=true
PROVIDER_SYNC_LIVE_TIMEOUT_SECONDS=30
PROVIDER_SYNC_LIVE_VERIFY_SSL=true

# Fill these with staging credentials before live DHA/KHIS/vendor validation.
PROVIDER_SYNC_LIVE_BASE_URLS={}
PROVIDER_SYNC_LIVE_BEARER_TOKENS={}
PROVIDER_SYNC_LIVE_API_KEYS={}
